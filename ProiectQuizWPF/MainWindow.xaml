<Window x:Class="ProiectQuizWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quiz App" Height="500" Width="800"
        WindowState="Maximized"
        Background="#1E1E2E">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <!-- Titlu -->
            <Label Content="Quiz App"
                   FontSize="36"
                   FontWeight="Bold"
                   Foreground="#CBA6F7"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

            <!-- Informatii Categorie -->
            <Border Background="#313244"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,0,15">
                <StackPanel>
                    <Label Content="Categorie"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#89B4FA"/>
                    <Label Name="lblNumeCategorie" Content="Geografie"/>
                    <Label Name="lblDificultate" Content="Dificultate: Usor"/>
                    <Label Name="lblNrIntrebari" Content="Numar intrebari: 5"/>
                </StackPanel>
            </Border>

            <!-- Informatii Jucator -->
            <Border Background="#313244"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,0,15">
                <StackPanel>
                    <Label Content="Jucator"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#A6E3A1"/>
                    <Label Name="lblNumeJucator" Content="Nume: Andrei"/>
                    <Label Name="lblScor" Content="Scor: 0"/>
                    <Label Name="lblNivel" Content="Nivel: Incepator"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</Window>